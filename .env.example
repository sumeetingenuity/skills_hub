# Clerk Authentication
# Get your keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_***
CLERK_SECRET_KEY=sk_test_***

# PostgreSQL Database
# Update with your connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skillhub?schema=public"

# Optional: Hub Signing Secret
# Used for HMAC-SHA256 signing of outbound webhook payloads
HUB_SIGNING_SECRET=

# Optional: GitHub Token
# Used to increase GitHub API rate limits for the import analyzer
GITHUB_TOKEN=

# Optional: OpenAI API Key
# Used for vector search embeddings
OPENAI_API_KEY=
